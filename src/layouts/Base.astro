---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noIndex?: boolean;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  includeTurnstile?: boolean;
  narrow?: boolean;
  navType?: 'main' | 'privacy';
}

const {
  title,
  description,
  canonical,
  noIndex = false,
  ogTitle,
  ogDescription,
  ogImage,
  ogImageWidth,
  ogImageHeight,
  includeTurnstile = false,
  narrow = false,
  navType = 'main',
} = Astro.props;
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {noIndex && <meta name="robots" content="noindex" />}
  {ogTitle && <meta property="og:title" content={ogTitle} />}
  {ogDescription && <meta property="og:description" content={ogDescription} />}
  <meta property="og:type" content="website" />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="DevsMachina" />
  <meta name="twitter:card" content="summary_large_image" />
  {ogTitle && <meta name="twitter:title" content={ogTitle} />}
  {ogDescription && <meta name="twitter:description" content={ogDescription} />}
  {canonical && <link rel="canonical" href={canonical} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {ogImageWidth && <meta property="og:image:width" content={ogImageWidth} />}
  {ogImageHeight && <meta property="og:image:height" content={ogImageHeight} />}
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" media="print" onload="this.onload=null;this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" /></noscript>
  {includeTurnstile && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onTurnstileLoad" defer></script>}
  <slot name="head" />
  <script src="/cdn-cgi/zaraz/i.js" defer></script>
</head>
<body class:list={[{ 'narrow-layout': narrow }]}>

  <nav>
    <div class="nav-inner">
      <a href={navType === 'privacy' ? '/' : '#'} class="nav-logo">devs<span>machina</span>.app</a>
      {navType === 'main' && <a href="#waitlist" class="nav-cta">Join Waitlist</a>}
      {navType === 'privacy' && <a href="/" class="nav-back">← Back</a>}
    </div>
  </nav>

  <slot />

  <footer>
    <div class="footer-inner">
      <div class="footer-logo">devs<span>machina</span>.app</div>
      <slot name="footer-right">
        <div class="footer-copy">© 2026 DevsMachina. All rights reserved.</div>
      </slot>
    </div>
  </footer>

  <div class="cookie-banner" id="cookie-banner">
    <div class="cookie-inner">
      <p class="cookie-text">This site uses cookies for spam prevention (Cloudflare Turnstile), analytics (Google Analytics 4), and loads fonts from Google Fonts. <a href="/privacy">Privacy Policy</a></p>
      <div class="cookie-actions">
        <button class="cookie-accept" onclick="acceptCookies()">Got it</button>
        <button class="cookie-decline" onclick="declineCookies()">Decline</button>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      if (!localStorage.getItem('cookie_consent')) {
        document.getElementById('cookie-banner').classList.add('visible');
      }
    })();
    function acceptCookies() {
      localStorage.setItem('cookie_consent', 'accepted');
      document.getElementById('cookie-banner').classList.remove('visible');
    }
    function declineCookies() {
      localStorage.setItem('cookie_consent', 'declined');
      document.getElementById('cookie-banner').classList.remove('visible');
    }
    document.body.classList.add('js-loaded');
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry, i) {
        if (entry.isIntersecting) {
          setTimeout(function() { entry.target.classList.add('visible'); }, i * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    reveals.forEach(function(el) { observer.observe(el); });
  </script>

  <slot name="scripts" />

</body>
</html>
