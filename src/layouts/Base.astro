---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noIndex?: boolean;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  includeTurnstile?: boolean;
  narrow?: boolean;  
}

const {
  title,
  description,
  canonical,
  noIndex = false,
  ogTitle,
  ogDescription,
  ogImage,
  ogImageWidth,
  ogImageHeight,
  includeTurnstile = false,
  narrow = false,
} = Astro.props;
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {noIndex && <meta name="robots" content="noindex" />}
  {ogTitle && <meta property="og:title" content={ogTitle} />}
  {ogDescription && <meta property="og:description" content={ogDescription} />}
  <meta property="og:type" content="website" />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="DevsMachina" />
  <meta name="twitter:card" content="summary_large_image" />
  {ogTitle && <meta name="twitter:title" content={ogTitle} />}
  {ogDescription && <meta name="twitter:description" content={ogDescription} />}
  {canonical && <link rel="canonical" href={canonical} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {ogImageWidth && <meta property="og:image:width" content={ogImageWidth} />}
  {ogImageHeight && <meta property="og:image:height" content={ogImageHeight} />}
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" media="print" onload="this.onload=null;this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" /></noscript>
  {includeTurnstile && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onTurnstileLoad" defer></script>}
  <script is:inline>
    window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag("consent","default",{analytics_storage:"denied",ad_storage:"denied",ad_user_data:"denied",ad_personalization:"denied"});function initGA4(){if(window.ga4Initialized)return;const e=document.createElement("script");e.async=!0;e.src="https://www.googletagmanager.com/gtag/js?id=G-710H8EVH08";document.head.appendChild(e);gtag("js",new Date);gtag("config","G-710H8EVH08",{anonymize_ip:!0});window.ga4Initialized=!0}if(localStorage.getItem("cookie_consent")==="accepted"){"complete"===document.readyState?setTimeout(initGA4,2000):window.addEventListener("load",()=>setTimeout(initGA4,2000));}
  </script>
  <slot name="head" />
</head>
<body class:list={[{ 'narrow-layout': narrow }]}>

  <nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">devs<span>machina</span>.app</a>

    <div class="nav-actions">
      <div class="nav-dropdown">
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
          Use Cases
        </button>
        <ul class="nav-dropdown-menu" role="menu">
          <li><a href="/use-cases" role="menuitem" class="nav-dropdown-overview">All Use Cases</a></li>
          <li><a href="/use-cases/operations-report" role="menuitem">Operations Report</a></li>
          <li><a href="/use-cases/seo-monitoring" role="menuitem">SEO Monitoring</a></li>
          <li><a href="/use-cases/cro-monitoring" role="menuitem">CRO Monitoring</a></li>
          <li><a href="/use-cases/pricing-intelligence" role="menuitem">Pricing Intelligence</a></li>
          <li><a href="/use-cases/inventory-signals" role="menuitem">Inventory Signals</a></li>
          <li><a href="/use-cases/landing-page-auditor" role="menuitem">Landing Page Auditor</a></li>
          <li><a href="/use-cases/localization-coverage" role="menuitem">Localization Coverage</a></li>
        </ul>
      </div>
      <a href="/#waitlist" class="nav-cta"><span class="nav-cta-short">Join</span><span class="nav-cta-full">Join Waitlist</span></a>
    </div>
  </div>
</nav>

  <slot />

  <footer>
  <div class="footer-inner">
    <a href="/" class="footer-logo">devs<span>machina</span>.app</a>
    <div class="footer-right">
      <div class="footer-links">
        <a href="/use-cases" class="footer-link">Use Cases</a>
        <a href="/privacy" class="footer-link">Privacy Policy</a>
        <a href="/sitemap.xml" class="footer-link" target="_blank" rel="noopener noreferrer">Sitemap</a>
      </div>
      <div class="footer-copy">© 2026 DevsMachina by AMMD WEB. All rights reserved.</div>
    </div>
  </div>
</footer>

  <div class="cookie-banner" id="cookie-banner">
    <div class="cookie-inner">
      <p class="cookie-text">This site uses cookies for spam prevention (Cloudflare Turnstile), loads fonts from Google Fonts, and uses Google Analytics (GA4) to understand how visitors use the site. <a href="/privacy">Privacy Policy</a></p>
      <div class="cookie-actions">
        <button class="cookie-accept" onclick="acceptCookies()">Got it</button>
        <button class="cookie-decline" onclick="declineCookies()">Decline</button>
      </div>
    </div>
  </div>

 <script is:inline>
    (function() {
      if (!localStorage.getItem('cookie_consent')) {
        document.getElementById('cookie-banner').classList.add('visible');
      }
    })();
    function acceptCookies() {
      localStorage.setItem('cookie_consent', 'accepted');
      document.getElementById('cookie-banner').classList.remove('visible');
      gtag("consent","update",{analytics_storage:"granted",ad_user_data:"granted",ad_personalization:"granted",ad_storage:"granted"});
      initGA4();
    }
    function declineCookies() {
      localStorage.setItem('cookie_consent', 'declined');
      document.getElementById('cookie-banner').classList.remove('visible');
    }
    document.body.classList.add('js-loaded');
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry, i) {
        if (entry.isIntersecting) {
          setTimeout(function() { entry.target.classList.add('visible'); }, i * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    reveals.forEach(function(el) { observer.observe(el); });
    // Nav dropdown
    (function() {
      var triggers = document.querySelectorAll('.nav-dropdown-trigger');
      triggers.forEach(function(trigger) {
        var menu = trigger.nextElementSibling;
        if (!menu) return;
        trigger.addEventListener('click', function(e) {
          e.stopPropagation();
          var open = trigger.getAttribute('aria-expanded') === 'true';
          triggers.forEach(function(t) { t.setAttribute('aria-expanded', 'false'); });
          trigger.setAttribute('aria-expanded', String(!open));
        });
      });
      document.addEventListener('click', function() {
        triggers.forEach(function(t) { t.setAttribute('aria-expanded', 'false'); });
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          triggers.forEach(function(t) { t.setAttribute('aria-expanded', 'false'); });
        }
      });
    })();
  </script>

  <slot name="scripts" />

</body>
</html>
